# Daedalus Deployment Configuration Template
# Copy this file to .env and update the values for your deployment

# =============================================================================
# VERSION CONFIGURATION
# =============================================================================
DAEDALUS_VERSION=0.1.0

# =============================================================================
# DOCKER CONFIGURATION
# =============================================================================
# Directory for docker volumes (use . for current directory)
DOCKER_VOLUME_DIRECTORY=.

# Docker registry for built images (e.g., ghcr.io/your-org, docker.io/your-user)
DOCKER_REGISTRY=docker.io/your-user

# =============================================================================
# DEPLOYMENT MODES
# =============================================================================
# DEPLOYMENT_MODE options:
# - "local": Local development with docker-compose (uses nginx proxy)
# - "kubernetes": Helm/Kubernetes deployment
DEPLOYMENT_MODE=kubernetes

# =============================================================================
# BACKEND ENDPOINT CONFIGURATION
# =============================================================================
# Host-only frontend/backend routing settings.
BACKEND_HOST=backend
BACKEND_NAMESPACE=daedalus
BACKEND_PORT=8000

# Full backend base URL for the autonomous worker.
BACKEND_BASE_URL=http://backend:8000

# Optional full chat-completion URL override for frontend initialization.
NEXT_PUBLIC_HTTP_CHAT_COMPLETION_URL=

DAEDALUS_PHOENIX_ENDPOINT=http://phoenix-svc.phoenix.svc.cluster.local:6006/v1/traces
PHOENIX_PROJECT_NAME="daedalus"
# Required when Phoenix auth is enabled. OTLP expects api_key=<PHOENIX_API_KEY>.
PHOENIX_API_KEY=
OTEL_EXPORTER_OTLP_HEADERS=
PHOENIX_CLIENT_HEADERS=

# Optional hosted OTLP tracing through NeMo Agent Toolkit's Arize AX exporter.
# Use in an Arize-specific backend config or --override path; Phoenix remains
# the default tracing sink in backend/tool-calling-config.yaml.
ARIZE_SPACE_ID=
ARIZE_API_KEY=
ARIZE_PROJECT_NAME=daedalus
ARIZE_USE_EU_REGION=false

# =============================================================================
# MCP Server CONFIGURATION
# https://github.com/tuttlebr/kubernetes-mcp-server
# =============================================================================
KUBERNETES_MCP_SERVER=http://k8s-mcp-server.k8s-mcp-server.svc.cluster.local:8080/mcp
KUBERNETES_MCP_TOKEN=
UNIFI_MCP_SERVER=
UNIFI_MCP_TOKEN=
# Google Workspace MCP OAuth client.
# Add this redirect URI to the Google OAuth client:
#   https://<your-public-host>/auth/redirect
GOOGLE_MCP_CLIENT_ID=
GOOGLE_MCP_CLIENT_SECRET=
GOOGLE_MCP_REDIRECT_URI=https://your-domain.example.com/auth/redirect

# Max concurrent async agent jobs executed per backend replica (F-010 semaphore).
MCP_MAX_CONCURRENT_JOBS=8

# =============================================================================
# NGINX CONFIGURATION
# =============================================================================
# Nginx ports
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379
APPROVAL_REDIS_URL=
RI_ACCEPT_TERMS_AND_CONDITIONS=1
RI_REDIS_HOST_DAEDALUS=redis
RI_REDIS_PORT_DAEDALUS=6379
RI_REDIS_ALIAS_DAEDALUS=Daedalus

# =============================================================================
# NV-INGEST CONFIGURATION
# =============================================================================
MILVUS_URI=http://milvus.milvus.svc.cluster.local:19530
MILVUS_USERNAME=
MILVUS_PASSWORD=
MILVUS_TOKEN=
NV_INGEST_HOST=http://nv-ingest.nv-ingest.svc.cluster.local
NV_INGEST_PORT=7670
MINIO_ENDPOINT=http://milvus-minio.milvus.svc.cluster.local:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=nv-ingest

# Direct document-ingest endpoint defaults.
DOCUMENT_INGEST_REQUEST_LIMIT=500
DOCUMENT_INGEST_CHUNK_SIZE=1024
DOCUMENT_INGEST_CHUNK_OVERLAP=150
DOCUMENT_INGEST_DEFAULT_COLLECTION=user_uploads
DOCUMENT_INGEST_EXTRACT_METHOD=pdfium
DOCUMENT_INGEST_USE_V2_API=false
DOCUMENT_INGEST_PDF_PAGES_PER_CHUNK=32
DOCUMENT_INGEST_ENABLE_IMAGE_FILTER=true
DOCUMENT_INGEST_ENABLE_CAPTIONING=false
DOCUMENT_INGEST_WORKER_POOL_SIZE=16
DOCUMENT_INGEST_BATCH_CONCURRENCY=1
DOCUMENT_INGEST_MAX_DOCUMENTS_PER_BATCH=20
# Max bytes per uploaded document, checked before base64 decode (F-020). 100 MiB.
DOCUMENT_INGEST_MAX_SIZE_BYTES=104857600
DOCUMENT_INGEST_REDIS_SOCKET_TIMEOUT=30
DOCUMENT_INGEST_REDIS_CONNECT_TIMEOUT=5
DOCUMENT_INGEST_TIMEOUT_SECONDS=300
DOCUMENT_INGEST_MAX_RETRIES=2
DOCUMENT_INGEST_RETRY_DELAY=1.0
# Hard cap (characters) on full-document markdown downloads (POST
# /v1/documents/markdown). Bounds server memory; default ~whole-document.
DOCUMENT_MARKDOWN_MAX_CHARS=20000000
# Per-user rate limit for the doc-to-markdown download route.
RATE_LIMIT_DOC_MARKDOWN_MAX=60
RATE_LIMIT_DOC_MARKDOWN_WINDOW_SECONDS=60
EMBEDDING_DENSE_DIM=2048
TOKENIZER=meta-llama/Llama-3.2-1B

# Frontend upload validation limits. NEXT_PUBLIC values are embedded in the
# browser bundle at build time; rebuild the frontend after changing them.
NEXT_PUBLIC_UPLOAD_IMAGE_SERVER_LIMIT_MB=100
NEXT_PUBLIC_UPLOAD_VIDEO_SERVER_LIMIT_MB=100
NEXT_PUBLIC_UPLOAD_DOCUMENT_SERVER_LIMIT_MB=200
NEXT_PUBLIC_UPLOAD_TRANSCRIPT_MAX_MB=50
NEXT_PUBLIC_UPLOAD_BASE64_OVERHEAD_FACTOR=0.75
NEXT_PUBLIC_UPLOAD_MAX_IMAGES_PER_BATCH=15
NEXT_PUBLIC_UPLOAD_MAX_DOCUMENTS_PER_BATCH=500
NEXT_PUBLIC_UPLOAD_MAX_VIDEOS_PER_BATCH=1
NEXT_PUBLIC_UPLOAD_IMAGE_COMPRESSION_THRESHOLD_KB=2000
NEXT_PUBLIC_UPLOAD_MAX_EXTRACTED_TEXT_CHARS=128000
NEXT_PUBLIC_UPLOAD_LARGE_DOCUMENT_THRESHOLD_KB=640

# Frontend runtime defaults.
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_WORKFLOW=Daedalus
NEXT_PUBLIC_CHAT_HISTORY_DEFAULT_ON=true
DEFAULT_MODEL=
FORCE_SECURE_COOKIES=false

# WebSocket sidecar and readiness checks.
WS_PORT=3001
WS_MAX_MESSAGE_BYTES=65536
WS_MAX_JOB_SUBSCRIPTIONS_PER_CONNECTION=50
WS_MAX_CHAT_SUBSCRIPTIONS_PER_CONNECTION=50
FRONTEND_READY_TIMEOUT_MS=1000

# Redis client resilience for frontend and WebSocket processes.
REDIS_MAX_RETRIES_PER_REQUEST=3
REDIS_COMMAND_TIMEOUT_MS=10000

# Optional browser push notifications.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Optional generated-image compatibility route.
GENERATED_IMAGE_LEGACY_PUBLIC=false


# =============================================================================
# NETWORK CONFIGURATION
# =============================================================================
# Docker network name
NETWORK_NAME=daedalus-network

# =============================================================================
# API Authentication
# =============================================================================
NVIDIA_API_KEY=
OPENAI_API_KEY=
SERPAPI_KEY=
PERPLEXITY_SEARCH_API_KEY=
GITHUB_PAT=
IMAGE_AUGMENTATION_BASE_URL=https://inference-api.nvidia.com/v1
IMAGE_AUGMENTATION_API_KEY=
IMAGE_AUGMENTATION_MODEL=gpt-image-1.5
IMAGE_COMPREHENSION_BASE_URL=https://inference-api.nvidia.com/v1
IMAGE_COMPREHENSION_API_KEY=
IMAGE_COMPREHENSION_MODEL=nvidia/NVIDIA-Nemotron-Nano-12B-v2
IMAGE_GENERATION_BASE_URL=https://inference-api.nvidia.com/v1
IMAGE_GENERATION_API_KEY=
IMAGE_GENERATION_MODEL=gpt-image-2

# =============================================================================
# EMBEDDING CONFIGURATION
# =============================================================================
EMBEDDING_BASE_URL=https://inference-api.nvidia.com/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=nvidia/llama-3.2-nv-embedqa-1b-v2

# =============================================================================
# RERANKER CONFIGURATION
# =============================================================================
RERANKER_BASE_URL=https://inference-api.nvidia.com/v1/ranking
RERANKER_API_KEY=
RERANKER_MODEL=nvidia/llama-3.2-nv-rerankqa-1b-v2

# =============================================================================
# LLM MODEL CONFIGURATION
# =============================================================================
# Default LLM (used by vtt_interpreter_tool)
DEFAULT_LLM_MODEL_BASE_URL=https://inference-api.nvidia.com/v1
DEFAULT_LLM_MODEL_API_KEY=
DEFAULT_LLM_MODEL_MODEL=nvidia/nemotron-3-super-120b-a12b

# Reasoning LLM
REASONING_LLM_MODEL_BASE_URL=https://inference-api.nvidia.com/v1
REASONING_LLM_MODEL_API_KEY=
REASONING_LLM_MODEL_MODEL=nvidia/nemotron-3-super-120b-a12b

# ReAct LLM (used by deep_thinker_tool)
REACT_LLM_MODEL_BASE_URL=https://inference-api.nvidia.com/v1
REACT_LLM_MODEL_API_KEY=
REACT_LLM_MODEL_MODEL=nvidia/nemotron-3-super-120b-a12b

# Tool-calling LLM (primary workflow LLM)
TOOL_CALLING_LLM_MODEL_BASE_URL=https://inference-api.nvidia.com/v1
TOOL_CALLING_LLM_MODEL_API_KEY=
TOOL_CALLING_LLM_MODEL_MODEL=nvidia/nemotron-3-super-120b-a12b

# Distillation LLM (fast/cheap model for summarization and extraction)
DISTILL_LLM_MODEL_BASE_URL=https://inference-api.nvidia.com/v1
DISTILL_LLM_MODEL_API_KEY=
DISTILL_LLM_MODEL_MODEL=nvidia/nemotron-3-super-120b-a12b

# LLM client resilience (applied via llm_diagnostics.py monkey-patch)
# Works around NAT/LangChain issue where ChatOpenAI disables httpx timeout.
# See: https://github.com/NVIDIA/NeMo-Agent-Toolkit/issues/1617
DAEDALUS_LLM_MAX_RETRIES=3
DAEDALUS_LLM_TIMEOUT=60.0

# =============================================================================
# User Configuration
# =============================================================================
# Required in production. Generate a unique value with:
#   openssl rand -base64 32
SESSION_SECRET=
# Shared token for trusted frontend-to-backend calls. Helm generates this
# automatically; set it manually for local Compose or non-Helm deployments.
DAEDALUS_INTERNAL_API_TOKEN=

# Optional: override the admin user for usage-debug and cross-user usage stats.
ADMIN_USERNAME=admin
USAGE_TRACKING_INTERNAL_TOKEN=

# Single-user auth fallback.
AUTH_USERNAME=
AUTH_PASSWORD=
AUTH_NAME=

# Login rate limits.
AUTH_LOGIN_WINDOW_SECONDS=300
AUTH_LOGIN_LOCKOUT_SECONDS=900
AUTH_LOGIN_MAX_ATTEMPTS=5

# User 1
AUTH_USER_1_USERNAME=
AUTH_USER_1_PASSWORD=
AUTH_USER_1_NAME=
# Default selected user for the initial login experience.
DAEDALUS_DEFAULT_USER=anonymous

# User 2
AUTH_USER_2_USERNAME=
AUTH_USER_2_PASSWORD=
AUTH_USER_2_NAME=

# =============================================================================
# BACKEND CONFIGURATION
# =============================================================================
NAT_CONFIG_FILE=/workspace/config.yaml
NAT_HOST=0.0.0.0
NAT_PORT=8000
NAT_LOG_LEVEL=INFO
BACKEND_API_PATH=/v1/chat/completions
# Direct uploaded-document ingestion bypasses NAT async jobs and streams
# structured progress back through /api/chat/async. Set to 0 only for
# emergency fallback to legacy NAT async document ingestion.
DAEDALUS_DIRECT_DOCUMENT_INGEST_STREAM=1
DOCUMENT_INGEST_TIMEOUT_MS=3600000
NAT_SUBMIT_MAX_RETRIES=2
NAT_RETRY_DELAY_MS=3000
NAT_CONNECTIVITY_TIMEOUT_MS=2000
NAT_SUBMIT_TIMEOUT_MS=45000
DAEDALUS_DEBUG_REPLAY=0

# =============================================================================
# AUTONOMOUS WORKER CONFIGURATION
# =============================================================================
AUTONOMOUS_USER_ID=default-user
AUTONOMY_INTERVAL_SECONDS=14400
AUTONOMY_WORKER_POLL_INTERVAL=10
AUTONOMY_WORKER_LEASE_TTL=60
AUTONOMY_RUN_ONCE=false
REQUEST_TIMEOUT=3600
ASYNC_POLL_INTERVAL=10
ASYNC_EXPIRY_SECONDS=3600
