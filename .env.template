# Daedalus Deployment Configuration Template
# Copy this file to .env and update the values for your deployment

# =============================================================================
# VERSION CONFIGURATION
# =============================================================================
DAEDALUS_VERSION=0.1.0

# =============================================================================
# DOCKER CONFIGURATION
# =============================================================================
# Directory for docker volumes (use . for current directory)
DOCKER_VOLUME_DIRECTORY=.

# Docker registry for built images (e.g., ghcr.io/your-org, docker.io/your-user)
DOCKER_REGISTRY=docker.io/your-user

# =============================================================================
# DEPLOYMENT MODES
# =============================================================================
# DEPLOYMENT_MODE options:
# - "local": Local development with docker-compose (uses nginx proxy)
# - "production": Production deployment with external backend
# - "standalone": Standalone deployment with custom endpoints
DEPLOYMENT_MODE=production

# =============================================================================
# BACKEND ENDPOINT CONFIGURATION
# =============================================================================
# Backend service configuration for different deployment modes

# For local/docker-compose deployments (DEPLOYMENT_MODE=local)
BACKEND_HOST=backend
BACKEND_PORT=8000

# For external backend deployments (DEPLOYMENT_MODE=production)
# Set the full backend URL when deploying frontend separately
EXTERNAL_BACKEND_URL=http://daedalus-backend.daedalus.svc.cluster.local:8000

# For standalone deployments (DEPLOYMENT_MODE=standalone)
# Custom backend endpoint
CUSTOM_BACKEND_HOST=localhost
CUSTOM_BACKEND_PORT=8000
CUSTOM_BACKEND_PROTOCOL=http

DAEDALUS_PHOENIX_ENDPOINT=http://phoenix-svc.phoenix.svc.cluster.local:6006/v1/traces
PHOENIX_COLLECTOR_ENDPOINT=http://phoenix-svc.phoenix.svc.cluster.local:6006
PHOENIX_PROJECT_NAME="daedalus"

# =============================================================================
# MCP Server CONFIGURATION
# https://github.com/tuttlebr/kubernetes-mcp-server
# =============================================================================
KUBERNETES_MCP_SERVER=http://k8s-mcp-server.k8s-mcp-server.svc.cluster.local:8080/mcp

# =============================================================================
# NGINX CONFIGURATION
# =============================================================================
# Nginx ports
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Enable/disable HTTPS (requires SSL certificates)
ENABLE_HTTPS=false

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_URL=redis://daedalus-redis.daedalus.svc.cluster.local
REDIS_PORT=6379
IMAGE_STORE_URL=daedalus-frontend.daedalus.svc.cluster.local/api/session/imageStorage
RI_ACCEPT_TERMS_AND_CONDITIONS=1
RI_REDIS_HOST_DAEDALUS=daedalus-redis.daedalus.svc.cluster.local
RI_REDIS_PORT_DAEDALUS=5540
RI_REDIS_ALIAS_DAEDALUS=Daedalus

# =============================================================================
# NV-INGEST CONFIGURATION
# =============================================================================
MILVUS_URI=http://milvus.milvus.svc.cluster.local:19530
NV_INGEST_HOST=http://nv-ingest.nv-ingest.svc.cluster.local
NV_INGEST_PORT=7670
MINIO_ENDPOINT=http://milvus-minio.milvus.svc.cluster.local:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin


# =============================================================================
# NETWORK CONFIGURATION
# =============================================================================
# Docker network name
NETWORK_NAME=daedalus-network

# =============================================================================
# SSL CONFIGURATION (for HTTPS)
# =============================================================================
# SSL certificate paths (relative to nginx/ssl directory)
SSL_CERT_FILE=tls.crt
SSL_KEY_FILE=tls.key

# =============================================================================
# API Authentication
# =============================================================================
NVIDIA_API_KEY=
NVIDIA_INFERENCE_API_KEY=
SERPAPI_KEY=
GITHUB_PAT=
NVIDIA_INFERENCE_BASE_URL=https://inference-api.nvidia.com/v1
IMAGE_AUGMENTATION_BASE_URL=https://inference-api.nvidia.com/v1
IMAGE_COMPREHENSION_BASE_URL=https://inference-api.nvidia.com/v1
IMAGE_GENERATION_BASE_URL=https://inference-api.nvidia.com/v1


# =============================================================================
# EMBEDDING CONFIGURATION
# =============================================================================
EMBEDDING_BASE_URL=https://inference-api.nvidia.com/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=nvidia/llama-3.2-nv-embedqa-1b-v2

# =============================================================================
# RERANKER CONFIGURATION
# =============================================================================
REANKER_BASE_URL=https://inference-api.nvidia.com/v1/ranking
REANKER_API_KEY=
REANKER_MODEL=nvidia/llama-3.2-nv-rerankqa-1b-v2

# =============================================================================
# LLM MODEL CONFIGURATION
# =============================================================================
# Default LLM (used by vtt_interpreter_tool)
DEFAULT_LLM_MODEL_BASE_URL=https://inference-api.nvidia.com/v1
DEFAULT_LLM_MODEL_API_KEY=
DEFAULT_LLM_MODEL_MODEL=nvidia/nemotron-3-super-120b-a12b

# Reasoning LLM
REASONING_LLM_MODEL_BASE_URL=https://inference-api.nvidia.com/v1
REASONING_LLM_MODEL_API_KEY=
REASONING_LLM_MODEL_MODEL=nvidia/nemotron-3-super-120b-a12b

# ReAct LLM (used by deep_thinker_tool)
REACT_LLM_MODEL_BASE_URL=https://inference-api.nvidia.com/v1
REACT_LLM_MODEL_API_KEY=
REACT_LLM_MODEL_MODEL=nvidia/nemotron-3-super-120b-a12b

# Tool-calling LLM (primary workflow LLM)
TOOL_CALLING_LLM_MODEL_BASE_URL=https://inference-api.nvidia.com/v1
TOOL_CALLING_LLM_MODEL_API_KEY=
TOOL_CALLING_LLM_MODEL_MODEL=nvidia/nemotron-3-super-120b-a12b

# Distillation LLM (fast/cheap model for summarization and extraction)
DISTILL_LLM_MODEL_BASE_URL=https://inference-api.nvidia.com/v1
DISTILL_LLM_MODEL_API_KEY=
DISTILL_LLM_MODEL_MODEL=nvidia/nemotron-3-super-120b-a12b

# LLM client resilience (applied via llm_diagnostics.py monkey-patch)
# Works around NAT/LangChain issue where ChatOpenAI disables httpx timeout.
# See: https://github.com/NVIDIA/NeMo-Agent-Toolkit/issues/1617
DAEDALUS_LLM_MAX_RETRIES=3
DAEDALUS_LLM_TIMEOUT=60.0

# =============================================================================
# User Configuration
# =============================================================================
# User 1
AUTH_USER_1_USERNAME=
AUTH_USER_1_PASSWORD=
AUTH_USER_1_NAME=
DAEDALUS_DEFAULT_USER=

# User 2
AUTH_USER_2_USERNAME=
AUTH_USER_2_PASSWORD=
AUTH_USER_2_NAME=

# =============================================================================
# BACKEND CONFIGURATION
# =============================================================================
BACKEND_API_PATH=/chat/stream

# =============================================================================
# ENVIRONMENT-SPECIFIC OVERRIDES
# =============================================================================
NEXT_PUBLIC_BASE_URL=daedalus-frontend.daedalus.svc.cluster.local:3000
