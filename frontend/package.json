{
  "name": "daedalus-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 5000 -H 0.0.0.0",
    "build": "next build && node scripts/inject-precache.js",
    "build:websocket": "esbuild ws-server.ts --bundle --platform=node --target=node22 --outfile=./ws-build/ws-server.js",
    "build:stream-worker": "esbuild stream-worker.ts --bundle --platform=node --target=node22 --external:sharp --external:web-push --outfile=./worker-build/stream-worker.js",
    "start": "next start -p 5000 -H 0.0.0.0",
    "start:stream-worker": "node stream-worker.js",
    "lint": "next lint",
    "format": "prettier --write .",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "e2e": "node e2e/run-e2e.mjs",
    "e2e:test": "playwright test"
  },
  "dependencies": {
    "@fontsource/ibm-plex-serif": "^5.2.7",
    "@tabler/icons-react": "^2.9.0",
    "@tanstack/react-query": "^5.62.0",
    "bcryptjs": "^2.4.3",
    "classnames": "^2.5.1",
    "cookie": "^0.7.2",
    "heic-decode": "^2.1.0",
    "html-to-image": "^1.11.11",
    "i18next": "^25.10.10",
    "immer": "^10.1.1",
    "ioredis": "^5.8.0",
    "katex": "^0.16.25",
    "mermaid": "^11.16.0",
    "next": "^15.5.20",
    "next-i18next": "^16.0.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-force-graph-2d": "^1.25.5",
    "react-hot-toast": "^2.4.0",
    "react-i18next": "^15.7.4",
    "react-markdown": "^8.0.5",
    "react-syntax-highlighter": "^16.1.1",
    "recharts": "^2.12.7",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^3.0.1",
    "remark-math": "^5.1.1",
    "sharp": "^0.33.2",
    "uuid": "^11.1.1",
    "web-push": "^3.6.7",
    "ws": "^8.21.1",
    "zustand": "^5.0.3"
  },
  "overrides": {
    "js-yaml": "^4.1.0",
    "esbuild": "0.25.12"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@tailwindcss/typography": "^0.5.9",
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "@types/bcryptjs": "^2.4.2",
    "@types/cookie": "^0.6.0",
    "@types/jsdom": "^21.1.1",
    "@types/node": "18.15.0",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "@types/react-syntax-highlighter": "^15.5.6",
    "@types/uuid": "^9.0.1",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.5.12",
    "@vitest/coverage-v8": "4.1.7",
    "autoprefixer": "^10.4.14",
    "esbuild": "0.25.12",
    "eslint": "~8.57.1",
    "eslint-config-next": "^15.5.20",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.21",
    "prettier": "^2.8.7",
    "prettier-plugin-tailwindcss": "^0.2.5",
    "tailwindcss": "^3.4.16",
    "typescript": "~5.5.0",
    "vite": "^7.3.6",
    "vitest": "4.1.7"
  }
}
