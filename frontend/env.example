# Backend API Configuration
# The API path to use when communicating with the NeMo Agent toolkit backend.
# Supported values:
#   /chat           - Non-streaming chat endpoint (NAT default)
#   /chat/stream    - Streaming chat endpoint (NAT default)
#   /generate       - Non-streaming generate endpoint
#   /generate/stream - Streaming generate endpoint
#   /v1/chat/completions - OpenAI-compatible endpoint (recommended)
BACKEND_API_PATH=/v1/chat/completions
BACKEND_HOST=backend
BACKEND_NAMESPACE=daedalus
BACKEND_PORT=8000
REDIS_URL=redis://redis:6379

# Required for signed identity cookies in production.
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# Frontend runtime defaults.
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_WORKFLOW=Daedalus
NEXT_PUBLIC_CHAT_HISTORY_DEFAULT_ON=true
DEFAULT_MODEL=

# Upload validation limits exposed to the browser at build time.
NEXT_PUBLIC_UPLOAD_IMAGE_SERVER_LIMIT_MB=100
NEXT_PUBLIC_UPLOAD_VIDEO_SERVER_LIMIT_MB=100
NEXT_PUBLIC_UPLOAD_DOCUMENT_SERVER_LIMIT_MB=200
NEXT_PUBLIC_UPLOAD_TRANSCRIPT_MAX_MB=50
NEXT_PUBLIC_UPLOAD_BASE64_OVERHEAD_FACTOR=0.75
NEXT_PUBLIC_UPLOAD_MAX_IMAGES_PER_BATCH=15
NEXT_PUBLIC_UPLOAD_MAX_DOCUMENTS_PER_BATCH=500
NEXT_PUBLIC_UPLOAD_MAX_VIDEOS_PER_BATCH=1
NEXT_PUBLIC_UPLOAD_IMAGE_COMPRESSION_THRESHOLD_KB=2000
NEXT_PUBLIC_UPLOAD_MAX_EXTRACTED_TEXT_CHARS=128000
NEXT_PUBLIC_UPLOAD_LARGE_DOCUMENT_THRESHOLD_KB=640

# Server-side document upload bounds. The route enforces this raw-byte limit;
# Next.js applies a static 268 MiB encoded request-body ceiling before it.
# Raw document limit. Values above 200 are clamped because Next's encoded JSON
# parser ceiling is a static 268 MiB; lower values tighten exact handler checks.
DOCUMENT_UPLOAD_MAX_MB=200
DOCUMENT_UPLOAD_MAX_CONCURRENT_PER_USER=2

# Optional runtime tuning.
STREAM_ABORT_POLL_INTERVAL_MS=1000
STREAM_READ_IDLE_TIMEOUT_MS=300000
FRONTEND_READY_TIMEOUT_MS=1000
WS_PORT=3001
WS_MAX_MESSAGE_BYTES=65536
WS_MAX_JOB_SUBSCRIPTIONS_PER_CONNECTION=50
WS_MAX_CHAT_SUBSCRIPTIONS_PER_CONNECTION=50
REDIS_MAX_RETRIES_PER_REQUEST=3
REDIS_COMMAND_TIMEOUT_MS=10000
AUTH_LOGIN_WINDOW_SECONDS=300
AUTH_LOGIN_LOCKOUT_SECONDS=900
AUTH_LOGIN_MAX_ATTEMPTS=5
USAGE_TRACKING_INTERNAL_TOKEN=

# Optional browser push notifications.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
