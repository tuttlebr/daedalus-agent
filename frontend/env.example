# Backend API Configuration
# The API path to use when communicating with the NeMo Agent toolkit backend.
# Supported values:
#   /chat           - Non-streaming chat endpoint (NAT default)
#   /chat/stream    - Streaming chat endpoint (NAT default, recommended)
#   /generate       - Non-streaming generate endpoint
#   /generate/stream - Streaming generate endpoint
#   /v1/chat/completions - OpenAI-compatible endpoint (single endpoint, uses stream param)
BACKEND_API_PATH=/chat/stream

# Required for signed identity cookies in production.
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# Upload validation limits exposed to the browser at build time.
NEXT_PUBLIC_UPLOAD_IMAGE_SERVER_LIMIT_MB=100
NEXT_PUBLIC_UPLOAD_VIDEO_SERVER_LIMIT_MB=100
NEXT_PUBLIC_UPLOAD_DOCUMENT_SERVER_LIMIT_MB=200
NEXT_PUBLIC_UPLOAD_TRANSCRIPT_MAX_MB=50
NEXT_PUBLIC_UPLOAD_BASE64_OVERHEAD_FACTOR=0.75
NEXT_PUBLIC_UPLOAD_MAX_IMAGES_PER_BATCH=15
NEXT_PUBLIC_UPLOAD_MAX_DOCUMENTS_PER_BATCH=500
NEXT_PUBLIC_UPLOAD_MAX_VIDEOS_PER_BATCH=1
NEXT_PUBLIC_UPLOAD_IMAGE_COMPRESSION_THRESHOLD_KB=2000
NEXT_PUBLIC_UPLOAD_MAX_EXTRACTED_TEXT_CHARS=128000
NEXT_PUBLIC_UPLOAD_LARGE_DOCUMENT_THRESHOLD_KB=640
